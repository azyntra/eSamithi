# eSamithi API Server — Environment Variables
# Copy this file to .env and fill in your values

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=esamithi_user
DB_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD
DB_NAME=esamithi

# JWT Authentication
JWT_SECRET=CHANGE_ME_TO_RANDOM_64_CHARACTER_STRING
JWT_EXPIRES_IN=24h

# Server
PORT=3000
NODE_ENV=production
