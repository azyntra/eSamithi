{
  "expo": {
    "name": "eSamithi",
    "slug": "esamithi-member",
    "version": "1.3.0",
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "updates": {
      "url": "https://u.expo.dev/741f24ff-0b1b-4b30-8034-08f7a6f8d7eb"
    },
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "esamithi",
    "userInterfaceStyle": "automatic",
    "extra": {
      "apiEnv": "prod",
      "apiUrls": {
        "prod": "https://api.esamithi.com/api/v1",
        "testbed": "http://212.227.103.150/api/v1"
      },
      "samithis": {
        "prod": "samithi01",
        "testbed": "test01"
      },
      "directoryUrl": "https://api.esamithi.com/directory",
      "router": {},
      "eas": {
        "projectId": "741f24ff-0b1b-4b30-8034-08f7a6f8d7eb"
      }
    },
    "ios": {
      "icon": "./assets/images/icon.png",
      "bundleIdentifier": "lk.esamithi.member",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "package": "lk.esamithi.member",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#1E6FD0",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0B1F3B",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 110,
          "dark": {
            "backgroundColor": "#0B1F3B"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#1E6FD0"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "owner": "azyntra-technologies"
  }
}
